{
  "name": "onesixty",
  "version": "0.1.0",
  "description": "AIP-160 filtering language parser and evaluator for TypeScript",
  "keywords": [
    "aip-160",
    "api",
    "evaluator",
    "filter",
    "filtering",
    "google",
    "list-filter",
    "parser",
    "query"
  ],
  "license": "Apache-2.0",
  "author": "lily <oss@colonthr.ee>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repository/onesixty.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "bench": "vitest bench",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "api:extract": "tsdown && cp dist/index.d.mts api/index.d.mts",
    "api:check": "tsdown && diff dist/index.d.mts api/index.d.mts",
    "playground": "tsx scripts/playground.ts",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "bumpp": "^11.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
